.venv
.git
.gitignore
.env
.env.*
!.env.example
.sessions
.transcripts
.agent_settings
.agent_settings_example
__pycache__
*.pyc
*.pyo
.pytest_cache

# Local persistence — mounted as volumes, not baked in.
.data
*.db
*.db-journal
*.db-wal
*.db-shm

# Per-agent workspaces are mounted at runtime, not baked.
agents/*/workspace/*
!agents/*/workspace/.gitkeep

# Docs and assets.
doc
prompt
*.md
!agents/README.md
*.png

# Tests.
tests

# Compose / orchestration files never belong inside an image.
docker-compose*.yml
local.sh
infra
