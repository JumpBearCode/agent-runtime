# =============================================================================
#  agent-runtime + agent-frontend — environment config
#
#  Copy to `.env` and fill in your own values. `.env` is gitignored.
#  `load_dotenv()` is called from both agent_runtime (core/config.py) and
#  agent_frontend (run.py), so a single repo-root .env serves both processes.
# =============================================================================


# ─── Model + provider (required) ─────────────────────────────────────────────

# Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here

# Model id. Required — no default.
MODEL_ID=claude-sonnet-4-6

# Optional: override Anthropic endpoint (for Anthropic-compatible providers —
# MiniMax, GLM, Kimi, DeepSeek, etc.). Leave unset for Anthropic native.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── Azure AI Foundry (optional, alternative to ANTHROPIC_API_KEY) ────────────
#
# agent_runtime/core/config.py:43 routes to the `AnthropicFoundry` client from
# the Anthropic SDK when either FOUNDRY_API_KEY or FOUNDRY_RESOURCE is set —
# bypassing the standard Anthropic client entirely. If you set any Foundry
# var below, leave ANTHROPIC_API_KEY unset (or it'll be ignored).
#
# To enable, provide:
#   1. ANTHROPIC_FOUNDRY_API_KEY          (required)
#   2. exactly ONE of:
#        ANTHROPIC_FOUNDRY_RESOURCE       — short resource name; SDK derives
#                                           https://{resource}.services.ai.azure.com/anthropic/
#        ANTHROPIC_FOUNDRY_BASE_URL       — full endpoint URL (custom domain,
#                                           private endpoint, proxy, etc.)
#   Setting BOTH raises a SDK ValueError ("mutually exclusive").
#
# MODEL_ID must be a deployment name available in your Foundry resource.
#
# ANTHROPIC_FOUNDRY_API_KEY=your-foundry-key-here
# ANTHROPIC_FOUNDRY_RESOURCE=your-foundry-resource-name
# ANTHROPIC_FOUNDRY_BASE_URL=https://your-private-endpoint.example.com/anthropic/


# ─── Anthropic-compatible providers (reference) ──────────────────────────────
#
#  Provider         MODEL_ID              SWE-bench  TB2     Base URL
#  ---------------  --------------------  ---------  ------  ---------
#  Anthropic        claude-sonnet-4-6     79.6%      59.1%   (default)
#  MiniMax          MiniMax-M2.5          80.2%        -     see below
#  GLM (Zhipu)      glm-5                 77.8%        -     see below
#  Kimi (Moonshot)  kimi-k2.5             76.8%        -     see below
#  DeepSeek         deepseek-chat (V3.2)  73.0%        -     see below
# ----- International -----
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic     # MiniMax
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic       # GLM
# ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic    # Kimi
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic   # DeepSeek
# ----- China mainland -----
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic   # MiniMax
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic   # GLM
# ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic    # Kimi


# ─── Runtime knobs (optional — defaults shown) ───────────────────────────────

# AGENT_NAME=                 # reported by /api/info; per-agent Dockerfiles set this
# AGENT_WORKDIR=              # default: cwd
# AGENT_SETTINGS_DIR=         # default: $AGENT_WORKDIR/.agent_settings (mcp.json + HITL.json)
# AGENT_SKILLS_DIR=           # default: $AGENT_WORKDIR/skills
# AGENT_SYSTEM_PROMPT_FILE=   # default: $AGENT_WORKDIR/prompts/system.md

# AGENT_HITL_TIMEOUT=600      # seconds before HITL auto-aborts
# AGENT_MAX_CONCURRENT_CHATS=64   # ThreadPoolExecutor max_workers
# TOOL_OUTPUT_LIMIT=10000     # max chars per tool result

# AGENT_THINKING=0            # 1 = enable extended thinking
# AGENT_THINKING_BUDGET=10000 # tokens

# AGENT_CORS_ORIGINS=*        # comma-separated for /api/*
# LOG_LEVEL=INFO


# ─── LangSmith observability (optional) ──────────────────────────────────────
#
# When LANGSMITH_TRACING=true, core/config.py wraps the Anthropic client with
# langsmith.wrappers.wrap_anthropic and the engine emits a parent span per
# round with child spans for each tool call + each HITL confirm.
#
# What gets sent:
#   • Every messages.stream() call (inputs, outputs, tokens, cache metrics, cost)
#   • One `agent_round` chain span per /api/chat (metadata: conversation_id,
#     trace_id, agent_name, model). conversation_id is also mirrored into
#     session_id so the LangSmith Threads tab groups multi-round chats.
#   • One `tool:<name>` span per tool dispatch
#   • One `hitl_confirm` child span per HITL-gated tool (request_id, wait_ms,
#     result: allow/deny/timeout/cancelled)
#
# Leave LANGSMITH_TRACING unset (or =false) to disable — @traceable is a no-op
# and the runtime pays zero overhead.
#
# WARNING: keep values on their own lines with NO trailing inline comments.
# docker --env-file does not strip `# ...` — it would leak into the value.
#
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_your-key-here
# LangSmith project (created automatically on first trace). Defaults to "default".
# LANGSMITH_PROJECT=agent-runtime
# LangSmith region endpoint. EU users: https://eu.api.smith.langchain.com
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# ─── Frontend (:8080) — optional ─────────────────────────────────────────────

# Comma-separated list of runtime URLs for the picker. First is the default.
# AGENT_RUNTIMES=http://localhost:8001

# Tenant partition key — wire to your auth claim once auth is added.
# CHAT_USER_ID=local

# Storage backend: `local` (SQLite) or `postgres`.
# CHAT_STORAGE=local
# CHAT_SQLITE_PATH=./agent_frontend.db
# CHAT_POSTGRES_URL=postgresql://user:pass@host:5432/chatdb


# ─── ADF agent (only when running the ADF MCP server) ────────────────────────
#
# Required by agents/adf-agent/mcp/adf_mcp_server.py — reads via os.environ[...]
# so unset = KeyError on import. If you're not running the ADF agent, leave the
# block unset. If you ARE running it (locally OR `docker run --env-file .env`),
# fill these with your Azure Data Factory coordinates.
#
# ADF_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
# ADF_RESOURCE_GROUP=your-resource-group
# ADF_FACTORY_NAME=your-factory-name
